{
  "name": "@floehq/sdk",
  "version": "0.2.4",
  "description": "TypeScript SDK for the Floe upload and file API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floehq/floe.git",
    "directory": "apps/sdk"
  },
  "homepage": "https://github.com/floehq/floe/tree/main/apps/sdk",
  "bugs": {
    "url": "https://github.com/floehq/floe/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "smoke": "npm run build && node ./examples/smoke.mjs",
    "test": "npm run build && node --test ./test/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
