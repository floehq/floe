{
  "name": "@floe/api",
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc",
    "test": "tsx --test --experimental-test-coverage ./test/*.test.ts 2>&1",
    "test:no-coverage": "tsx --test ./test/*.test.ts",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" && prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@mysten/bcs": "^2.1.0",
    "@mysten/sui": "^1.21.1",
    "@sentry/node": "^10.65.0",
    "@upstash/redis": "^1.34.3",
    "fastify": "^5.8.5",
    "p-queue": "^8.0.0",
    "pg": "^8.13.1",
    "undici": "^6.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
