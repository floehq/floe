PORT=3001
NODE_ENV=development
FLOE_NODE_ROLE=full
UPLOAD_TMP_DIR=/absolute/path/to/Floe/apps/api/tmp/uploads
FLOE_CHUNK_STORE_MODE=disk
FLOE_REDIS_PROVIDER=native
REDIS_URL=redis://127.0.0.1:6379
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_FALLBACK_URLS=https://wal-aggregator-testnet.staketab.org,https://walrus-testnet-aggregator.nodes.guru,https://walrus-aggregator.rubynodes.io
FLOE_WALRUS_STORE_MODE=publisher
FLOE_WALRUS_PUBLISHER_BASE_URL=https://publisher.walrus-testnet.walrus.space
FLOE_NETWORK=testnet
SUI_PRIVATE_KEY=suiprivkey...
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0x...
TATUM_API_KEY=
TATUM_NATIVE_CONTRACT_ADDRESS=0x<your-tatum-collection-contract>
TATUM_TEST_PRIVATE_KEY=
TATUM_SIGNATURE_ID=
FLOE_AUTH_MODE=private
FLOE_AUTH_PROVIDER=external
FLOE_AUTH_EXTERNAL_VERIFY_URL=http://127.0.0.1:4000/floe/auth/verify
# Must match Floe-private/.env.integration.local:FLOE_VERIFY_SHARED_SECRET
FLOE_AUTH_EXTERNAL_SHARED_SECRET=replace-me
FLOE_AUTH_EXTERNAL_TIMEOUT_MS=2000
# Keep this near zero for revoke/rotate smoke checks against the SaaS verifier.
FLOE_AUTH_EXTERNAL_CACHE_TTL_MS=1
FLOE_PUBLIC_MAX_FILE_SIZE_BYTES=5242880
FLOE_AUTH_MAX_FILE_SIZE_BYTES=10485760
